# ==========================================
# COS-AA Environment Configuration
# Copy to .env for local development
# ==========================================

# Application
APP_ENV=development
APP_SECRET_KEY=dev-secret-change-in-production
LOG_LEVEL=INFO
LOG_FORMAT=json
CORS_DOMAIN=<YOUR_DOMAIN>

# PostgreSQL
POSTGRES_URL=postgresql+asyncpg://cos_user:cos_pass@localhost:5432/cos_aa
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# LLM
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Vector DB
VECTOR_BACKEND=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1

# Auth
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# OAuth (get credentials from each provider's developer console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
OAUTH_REDIRECT_BASE_URL=http://localhost:5173

# Vault (production only)
VAULT_ADDR=
VAULT_ROLE=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Observability
OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# Self-evolving agents
SPAWN_THRESHOLD=3
SPAWN_WINDOW_SECONDS=86400
CONTAINER_REGISTRY=ghcr.io/<GITHUB_ORG>/cos-aa

# OODA defaults
DEFAULT_MAX_OODA_ITERATIONS=5
DEFAULT_OODA_CYCLE_TIMEOUT_SECONDS=120
DEFAULT_HUMAN_CONFIRMATION_TIMEOUT_SECONDS=60
COT_CONFIDENCE_THRESHOLD=0.6
